      "id": "e_p01",
      "claim": "Brain-derived neurotrophic factor (BDNF) activates TrkB receptors at hippocampal synapses, triggering downstream MAPK/ERK signalling that enhances long-term potentiation (LTP).",
      "source": "Nature Neuroscience",
      "evidence_type": "CONTROLLED_EXPERIMENT",
      "year": 2022,
      "sample_n": 240,
      "epistemic_quality": 0.8243,
